# ==========================================
# VENDOR BRIDGE - Environment Configuration
# Copy this file to ".env" and fill in values
# ==========================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/vendorbridge?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/vendorbridge

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins, or leave blank for allow-all in development)
CORS_ORIGINS=

# Email (Nodemailer) - optional. If left blank, emails are logged to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=VENDOR BRIDGE <no-reply@vendorbridge.com>
